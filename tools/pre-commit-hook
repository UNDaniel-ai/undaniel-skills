#!/usr/bin/env bash
#
# Git pre-commit hook for lulu-skills-common
# Validates SKILL.md files before committing
#
# Installation:
#   bash tools/install-hooks.sh
#
# Manual installation:
#   ln -sf ../../tools/pre-commit-hook .git/hooks/pre-commit
#   chmod +x tools/pre-commit-hook
#
# Bypass:
#   git commit --no-verify

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get repository root
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${REPO_ROOT}"

# Validation tool path
VALIDATOR="${REPO_ROOT}/tools/quick_validate.py"

# Check if validator exists
if [[ ! -f "${VALIDATOR}" ]]; then
  echo -e "${RED}❌ Error: Validation tool not found at ${VALIDATOR}${NC}"
  echo "Skipping validation..."
  exit 0
fi

# Get list of staged SKILL.md files
STAGED_SKILLS=$(git diff --cached --name-only --diff-filter=ACM | \
  grep -E 'skills/.*/SKILL\.md$' | \
  grep -v '.test-skill' || true)

# If no SKILL.md files are staged, exit successfully
if [[ -z "${STAGED_SKILLS}" ]]; then
  exit 0
fi

# Count total skills to validate
TOTAL_SKILLS=$(echo "${STAGED_SKILLS}" | wc -l | tr -d ' ')

echo -e "${BLUE}🔍 Running skill validation...${NC}"
echo "Found ${TOTAL_SKILLS} modified skill(s):"

# Track validation results
FAILED_SKILLS=()
VALIDATION_EXIT_CODE=0

# Validate each staged skill
while IFS= read -r skill_file; do
  # Extract skill name from path (skills/AIWay/SKILL.md -> AIWay)
  skill_name=$(echo "${skill_file}" | sed -E 's|skills/([^/]+)/SKILL\.md|\1|')

  echo -e "  - ${skill_name}"

  # Run validation (suppress output, we'll show it at the end if it fails)
  if ! python3 "${VALIDATOR}" --skill "${skill_name}" > /tmp/skill-validation-${skill_name}.log 2>&1; then
    FAILED_SKILLS+=("${skill_name}")
    VALIDATION_EXIT_CODE=1
  fi
done <<< "${STAGED_SKILLS}"

echo ""

# Report results
if [[ ${VALIDATION_EXIT_CODE} -eq 0 ]]; then
  echo -e "${GREEN}✅ All skills validated successfully${NC}"
  exit 0
else
  echo -e "${RED}❌ Validation failed for ${#FAILED_SKILLS[@]} skill(s):${NC}"
  for skill in "${FAILED_SKILLS[@]}"; do
    echo -e "${RED}  - ${skill}${NC}"
    echo ""
    echo "--- Validation output for ${skill} ---"
    cat "/tmp/skill-validation-${skill}.log"
    echo "--- End of ${skill} output ---"
    echo ""
  done

  echo -e "${YELLOW}To fix:${NC}"
  echo "  1. Review and fix the errors above"
  echo "  2. Stage your changes: git add <files>"
  echo "  3. Commit again"
  echo ""
  echo -e "${YELLOW}To bypass this check (not recommended):${NC}"
  echo "  git commit --no-verify"
  echo ""

  exit 1
fi
